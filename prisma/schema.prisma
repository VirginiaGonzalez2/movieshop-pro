generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model IntegrationConfig {
  id        Int      @id @default(autoincrement())
  platform  String
  apiKey    String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoBar {
  id           Int      @id @default(autoincrement())
  promoText    String
  endDate      DateTime
  visiblePages String
  color        String
  updatedAt    DateTime @updatedAt
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user {
  id            String         @id
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  banExpires    DateTime?
  banReason     String?
  banned        Boolean        @default(false)
  role          String         @default("user")
  ratings       MovieRating[]
  orders        Order[]
  wishlist      WishlistItem[]
  account       account[]
  session       session[]
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([identifier])
}

model Movie {
  id                Int                 @id @default(autoincrement())
  title             String
  description       String
  price             Decimal
  releaseDate       DateTime
  runtime           Int
  imageUrl          String?
  stock             Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  trailerUrl        String?
  discountCodeLinks DiscountCodeMovie[]
  genres            MovieGenre[]
  people            MoviePerson[]
  ratings           MovieRating[]
  orderItems        OrderItem[]
  wishlistedBy      WishlistItem[]
}

model Genre {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  movies      MovieGenre[]
}

model Person {
  id     Int           @id @default(autoincrement())
  name   String
  bio    String?
  movies MoviePerson[]
}

model MovieGenre {
  movieId Int
  genreId Int
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)
  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model MoviePerson {
  movieId  Int
  personId Int
  role     Role
  movie    Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([movieId, personId, role])
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      String
  totalAmount Decimal
  status      OrderStatus
  orderDate   DateTime    @default(now())
  authUserId  String?
  user        user?       @relation(fields: [authUserId], references: [id])
  items       OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderDate])
  @@index([authUserId])
  @@index([status, orderDate])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  movieId         Int
  quantity        Int
  priceAtPurchase Decimal
  movie           Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([movieId])
}

model MovieRating {
  id        Int      @id @default(autoincrement())
  movieId   Int
  userId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
  @@index([movieId])
  @@index([userId])
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  movieId   Int
  userId    String
  createdAt DateTime @default(now())
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
  @@index([movieId])
  @@index([userId])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model DiscountCode {
  id         Int                 @id @default(autoincrement())
  code       String              @unique
  type       DiscountType
  value      Decimal
  scope      DiscountScope
  startsAt   DateTime?
  endsAt     DateTime?
  isActive   Boolean             @default(true)
  usageLimit Int?
  usageCount Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  products   DiscountCodeMovie[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model DiscountCodeMovie {
  discountCodeId Int
  movieId        Int
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  movie          Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([discountCodeId, movieId])
  @@index([movieId])
}

model AnalyticsConfig {
  id        Int      @id @default(autoincrement())
  gaId      String?
  gtmId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ACTOR
  DIRECTOR
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountScope {
  ALL_PRODUCTS
  SELECTED_PRODUCTS
}
