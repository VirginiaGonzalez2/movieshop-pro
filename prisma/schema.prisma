generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Decimal
  releaseDate DateTime
  runtime     Int
  imageUrl    String?
  stock       Int

  genres      MovieGenre[]
  people      MoviePerson[]
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Genre {
  id          Int     @id @default(autoincrement())
  name        String @unique
  description String?

  movies      MovieGenre[]
}

model Person {
  id     Int     @id @default(autoincrement())
  name   String
  bio    String?

  movies MoviePerson[]
}

model MovieGenre {
  movieId Int
  genreId Int

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model MoviePerson {
  movieId  Int
  personId Int
  role     Role

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([movieId, personId, role])
}

enum Role {
  ACTOR
  DIRECTOR
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      String
  totalAmount Decimal
  status      String
  orderDate   DateTime @default(now())

  items       OrderItem[]
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  movieId         Int
  quantity        Int
  priceAtPurchase Decimal

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}